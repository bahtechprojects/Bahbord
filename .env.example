# Database
DATABASE_URL=postgres://user:password@localhost:5432/bahboard

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_xxx

# Supabase (realtime features)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MongoDB (NoSQL - acessos, audits, time logs)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bahjira

# Google Drive (file uploads - substitui Supabase Storage)
# Criar Service Account em console.cloud.google.com, baixar JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_folder_id

# Anthropic (AI features)
ANTHROPIC_API_KEY=

# Webhooks outbound (obrigatório para endpoint /api/webhooks)
WEBHOOK_SECRET=your_webhook_secret

# GitHub Integration (webhook em /api/webhooks/github)
GITHUB_WEBHOOK_SECRET=

# WhatsApp/UazAPI (opcional)
WHATSAPP_API_URL=https://api.uazapi.com
WHATSAPP_API_TOKEN=your_whatsapp_token

# Email (Resend) — opcional, sistema funciona sem mas não envia welcome email
RESEND_API_KEY=
EMAIL_FROM="Bah!Flow <noreply@projetos.bahtech.com.br>"

# Sentry (error monitoring) — opcional
# DSN público é necessário no client e no server pra capturar erros
NEXT_PUBLIC_SENTRY_DSN=
# Auth token só é usado em build pra subir source maps (CI/CD)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Backup (usado por scripts/backup-db.sh e .github/workflows/backup.yml)
BACKUP_S3_BUCKET=
